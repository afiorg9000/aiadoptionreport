  --color-sme: hsl(var(--llpa-orange));
}
</style><div class="recharts-responsive-container" style="width: 100%; height: 100%; min-width: 0px;color: rgb(29, 38, 48); font-size: 12px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><div class="recharts-responsive-container" style="width: 974px; height: 320px; min-width: 0px;color: rgb(29, 38, 48); font-size: 12px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><div class="recharts-wrapper" style="position: relative; cursor: default; width: 100%; height: 100%; max-height: 320px; max-width: 974px;color: rgb(29, 38, 48); font-size: 12px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><svg class="recharts-surface" width="974" height="320" viewBox="0 0 974 320" style="width: 100%; height: 100%;"><title></title><desc></desc><defs><clipPath id="recharts1-clip"><rect x="60" y="20" height="148" width="884"></rect></clipPath></defs><defs><linearGradient id="gradientLarge" x1="0" y1="0" x2="0" y2="1"><stop offset="5%" stop-color="hsl(var(--llpa-blue))" stop-opacity="0.8"></stop><stop offset="95%" stop-color="hsl(var(--llpa-blue))" stop-opacity="0.2"></stop></linearGradient><linearGradient id="gradientSME" x1="0" y1="0" x2="0" y2="1"><stop offset="5%" stop-color="hsl(var(--llpa-orange))" stop-opacity="0.8"></stop><stop offset="95%" stop-color="hsl(var(--llpa-orange