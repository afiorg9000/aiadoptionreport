30, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">High individual generative AI usage — Google/Ipsos 2025 survey shows 49% of Australians employed generative AI in the last year, up from 38% in 2023, with 74% of AI users integrating tools into work.</span><a href="#mp-ref-28" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[28]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-emerald-600 mt-1" style="color: rgb(5, 150, 105); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">✓</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Strong government investment and policy support — Australian Government allocated $124 million toward AI research and development. National AI Centre's AI Adoption Tracker provides detailed market intelligence.</span><a href="#mp-ref-27" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[27]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span><a href="#mp-ref-22" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[22]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-emerald-600 mt-1" style="color: rgb(5, 150, 105); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">✓</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Sector-specific opportunities in mining and resources — Major extractives sector creates specialized industrial AI training opportunities for predictive maintenance, exploration optimization, and operational efficiency.</span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-emerald-600 mt-1" style="color: rgb(5, 150, 105); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">✓</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Demonstrated ROI driving adoption — 48% of businesses report positive ROI within first year of implementing AI solutions, supporting business case for training investment.</span><a href="#mp-ref-27" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[27]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li></ul></div><div style="color: rgb(29, 38, 48); font-size: 16px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><h4 class="text-sm font-semibold text-red-700 uppercase tracking-wide mb-3 flex items-center gap-2" style="color: rgb(185, 28, 28); font-weight: 600; font-size: 14px; margin-bottom: 12px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-triangle-alert w-4 h-4"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>Weaknesses</h4><ul class="space-y-2"><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-red-600 mt-1" style="color: rgb(220, 38, 38); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">•</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Trust deficit despite growing usage — KPMG global study reveals Australia lags in AI trust despite growing usage, creating need for change management and responsible AI training integration.</span><a href="#mp-ref-412" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[412]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-red-600 mt-1" style="color: rgb(220, 38, 38); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">•</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">SME adoption significantly lower than large enterprises — Only 20% SME adoption compared to 60% for large enterprises (500+ employees) indicates significant market development opportunity but also structural barriers.</span><a href="#mp-ref-27" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[27]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-red-600 mt-1" style="color: rgb(220, 38, 38); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">•</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Cautious enterprise approach compared to global leaders — RBA research indicates 'adoption of AI at an enterprise scale is still at a very early stage and largely for pilot or experimental purposes,' suggesting conservative deployment patterns.</span><a href="#mp-ref-24" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[24]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-red-600 mt-1" style="color: rgb(220, 38, 38); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">•</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">AI talent concentration below global leaders — Australia's relative performance across AI skill penetration and AI talent concentration is lower than other countries, reflecting cautious adoption approach.</span><a href="#mp-ref-24" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[24]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></span></li><li class="text-sm text-muted-foreground flex gap-2" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 8px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-red-600 mt-1" style="color: rgb(220, 38, 38); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">•</span><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Geographic isolation affecting training delivery — Distance from major AI hubs creates challenges for instructor recruitment and international training partnerships.</span></span></li></ul></div></div><div class="pt-4 border-t border-border" style="color: rgb(29, 38, 48); font-size: 16px; padding: 16px 0px 0px; padding-top: 16px; margin-top: 24px; border-top: 1px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 1px 0px 0px;"><h4 class="text-sm font-semibold text-foreground uppercase tracking-wide mb-3" style="color: rgb(29, 38, 48); font-weight: 600; font-size: 14px; margin-bottom: 12px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Comparative Context</h4><div class="grid md:grid-cols-2 gap-4 text-sm" style="color: rgb(29, 38, 48); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><div style="color: rgb(29, 38, 48); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="font-medium text-foreground" style="color: rgb(29, 38, 48); font-weight: 500; font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">In Asia-Pacific:</span><p class="text-muted-foreground mt-1" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Australia leads alongside Singapore in AI adoption within the region. Strong government support and enterprise investment create substantial training market opportunity.</span></p></div><div style="color: rgb(29, 38, 48); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="font-medium text-foreground" style="color: rgb(29, 38, 48); font-weight: 500; font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Globally:</span><p class="text-muted-foreground mt-1" style="color: rgb(103, 115, 126); font-size: 14px; margin-top: 4px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">Australia's 140%+ enterprise AI growth rate positions it among fastest-growing markets globally. The combination of high consumer adoption (49%) and enterprise investment creates strong foundation for continued expansion.</span><a href="#mp-ref-26" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[26]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span><a href="#mp-ref-28" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[28]</a><span style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"></span></p></div></div></div></div></div></div></section><section id="region-americas" class="mb-12 scroll-mt-24" style=" color: rgb(29, 38, 48); font-size: 16px; margin-bottom: 48px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><h2 class="text-2xl font-bold text-foreground mb-6 flex items-center gap-2" style="color: rgb(29, 38, 48); font-weight: 700; font-size: 24px; margin-bottom: 24px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe w-6 h-6 text-steel"><circle cx="12" cy="12" r="10"></circle><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path d="M2 12h20"></path></svg>Americas</h2><div class="space-y-6" style="color: rgb(29, 38, 48); font-size: 16px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><div id="country-mexico" class