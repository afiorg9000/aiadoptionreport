, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span class="text-muted-foreground" style="color: rgb(103, 115, 126); font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">GenAI individual usage:</span><span class="font-medium text-foreground" style="color: rgb(29, 38, 48); font-weight: 500; font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;"><span style="color: rgb(29, 38, 48); font-weight: 500; font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">22% (below EU average)</span><a href="#mp-ref-69" class="text-llpa-blue hover:text-llpa-blue/80 cursor-pointer font-medium text-[10px] align-super" style="color: rgb(32, 159, 223); font-weight: 500; font-size: 10px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-left: 0px solid rgb(224, 230, 235); border-color: rgb(224, 230, 235); border-style: solid; border-width: 0px;">[69]</a><span style="color: rgb(29, 38, 48); font-weight: 500; font-size: 14px; border: 0px solid rgb(224, 230, 235); border-top: 0px solid rgb(224, 230, 235); border-right: 0px solid rgb(224, 230, 235); border-bottom: 0px solid rgb(224, 230, 235); border-